# VARDAx Environment Variables Template
# Copy this file to .env and fill in your values

# Database Configuration
POSTGRES_USER=vardax
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=vardax

# Security (REQUIRED)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
VARDAX_JWT_SECRET=your-jwt-secret-here

# ML Configuration
VARDAX_ANOMALY_THRESHOLD=0.7
VARDAX_SESSION_WINDOW_SECONDS=300
VARDAX_RATE_WINDOW_SECONDS=60

# Optional: External Services
# VARDAX_REDIS_URL=redis://redis:6379
# VARDAX_DATABASE_URL=postgresql://vardax:password@postgres:5432/vardax
