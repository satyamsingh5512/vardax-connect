# VARDAx Production Environment Variables
# Copy this file to .env.production and fill in your values

# ============================================================================
# SECURITY (CHANGE ALL OF THESE!)
# ============================================================================
VARDAX_API_KEY=your-secure-api-key-here-min-32-chars
JWT_SECRET=your-jwt-secret-here-min-32-chars
POSTGRES_PASSWORD=your-postgres-password-here
REDIS_PASSWORD=your-redis-password-here
GRAFANA_PASSWORD=your-grafana-password-here

# ============================================================================
# APPLICATION
# ============================================================================
BACKEND_IMAGE=your-registry/your-app:latest
VITE_API_URL=https://your-domain.com/api/v1

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://vardax:${POSTGRES_PASSWORD}@postgres:5432/vardax

# ============================================================================
# ML CONFIGURATION
# ============================================================================
ANOMALY_THRESHOLD=0.7
SESSION_WINDOW_SECONDS=300
RATE_WINDOW_SECONDS=60

# ============================================================================
# DEPLOYMENT
# ============================================================================
COMPOSE_PROJECT_NAME=vardax
COMPOSE_FILE=docker-compose.prod.yml

# ============================================================================
# MONITORING
# ============================================================================
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true

# ============================================================================
# SSL/TLS
# ============================================================================
# Place your SSL certificates in nginx/ssl/
# cert.pem and key.pem
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem
