{
  "name": "vardax-connect",
  "version": "1.1.0",
  "description": "Connect any Node.js/Express app to VARDAx ML-Powered WAF - one command, zero config",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "node test/test.js",
    "test:firewall": "npx ts-node src/firewall-middleware.test.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vardax",
    "waf",
    "security",
    "firewall",
    "ml",
    "anomaly-detection",
    "middleware",
    "express",
    "rate-limiting",
    "ddos-protection"
  ],
  "author": "VARDAx Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satyamsingh5512/vardax-connect.git"
  },
  "homepage": "https://github.com/satyamsingh5512/vardax-connect#readme",
  "bugs": {
    "url": "https://github.com/satyamsingh5512/vardax-connect/issues"
  },
  "dependencies": {
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "lib/",
    "dist/",
    "src/firewall-middleware.ts",
    "README.md",
    "LICENSE"
  ]
}
