# Production environment variables for external website
# This should be used when the frontend is hosted externally and needs to connect to the local backend via ngrok

# Backend API URL (ngrok tunnel)
VITE_API_URL=https://spectrological-cinda-unfunereally.ngrok-free.dev

# WebSocket URL (ngrok tunnel with wss protocol)
VITE_WS_URL=wss://spectrological-cinda-unfunereally.ngrok-free.dev

# Enable production mode
NODE_ENV=production