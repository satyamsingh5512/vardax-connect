# Sentinelas Environment Configuration
# Copy to .env and customize

# WAF Ports
WAF_HTTP_PORT=8080
WAF_HTTPS_PORT=8443

# ML Service
ML_HTTP_PORT=8000
ML_GRPC_PORT=50051
BATCH_SIZE=32
INFERENCE_TIMEOUT_MS=10

# gRPC Configuration
GRPC_TIMEOUT_MS=10
SHADOW_MODE=false

# Redis
REDIS_PORT=6379

# TimescaleDB
TSDB_PORT=5432
TSDB_USER=sentinelas
TSDB_PASSWORD=sentinelas
TSDB_DB=sentinelas

# Dashboard
DASHBOARD_PORT=3000

# Logging
LOG_LEVEL=info
