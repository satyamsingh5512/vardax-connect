{
  "name": "vardax",
  "version": "1.0.0",
  "description": "VARDAx - ML-Powered WAF Anomaly Detection System",
  "scripts": {
    "setup": "bash setup.sh",
    "start": "bash start.sh",
    "stop": "bash stop.sh",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && source venv/bin/activate && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8001",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "bash scripts/run_all_tests.sh",
    "test:backend": "backend/venv/bin/python -m pytest backend/tests/ -v",
    "test:ml": "backend/venv/bin/python -m pytest backend/tests/test_ml_models.py -v",
    "test:features": "backend/venv/bin/python -m pytest backend/tests/test_feature_extractor.py -v",
    "test:fortress": "backend/venv/bin/python -m pytest fortress/tests/ -v",
    "test:connect": "node vardax-connect/test/test-comprehensive.js",
    "test:quick": "backend/venv/bin/python scripts/quick_test.py"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "author": "VARDAx Team",
  "license": "MIT",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/satyamsingh5512/vardax-connect.git"
  },
  "bugs": {
    "url": "https://github.com/satyamsingh5512/vardax-connect/issues"
  },
  "homepage": "https://github.com/satyamsingh5512/vardax-connect#readme",
  "dependencies": {
    "vardax-connect": "^1.0.0"
  }
}
